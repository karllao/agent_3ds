# ============================================================
# CAD-to-MAX Agent 后端环境变量配置
# 复制此文件为 .env 并填写真实值
# ============================================================

# 调试模式（true 时开启 /docs 和详细错误信息）
DEBUG=true

# 安全密钥（生产环境请使用随机长字符串）
SECRET_KEY=your-secret-key-change-this-in-production

# ── 数据库 ──────────────────────────────────────────────────
# PostgreSQL 异步连接 URL
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/cad_agent

# ── Redis ───────────────────────────────────────────────────
# Redis 连接 URL（Celery broker 和 result backend）
REDIS_URL=redis://localhost:6379/0

# ── AI 服务 ─────────────────────────────────────────────────
# OpenAI API Key（sk-开头）
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic API Key（sk-ant-开头）
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# OpenAI / OpenAI 兼容接口的 Base URL（可选，留空则用官方地址 https://api.openai.com/v1）
# 用于自建代理、Azure OpenAI、第三方兼容服务等
# OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic / Anthropic 兼容接口的 Base URL（可选，留空则用官方地址 https://api.anthropic.com）
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# 默认使用的 LLM 提供商：openai 或 anthropic
DEFAULT_LLM_PROVIDER=openai

# 默认模型名称
DEFAULT_MODEL=gpt-4o

# LLM 温度（0.0-2.0，建议 0.2-0.5）
LLM_TEMPERATURE=0.3

# ── 3ds Max Worker ──────────────────────────────────────────
# Windows 机器上运行的 max_worker 服务地址
MAX_WORKER_URL=http://localhost:8765

# ── 文件存储 ────────────────────────────────────────────────
# 文件存储根路径（CAD文件、场景JSON、max文件、预览图）
STORAGE_PATH=/data/storage

# ── CORS ────────────────────────────────────────────────────
# 允许跨域的前端地址（JSON 数组格式）
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Celery ──────────────────────────────────────────────────
# 任务软超时（秒）
CELERY_TASK_SOFT_TIME_LIMIT=600

# 任务硬超时（秒）
CELERY_TASK_TIME_LIMIT=900
