# ============================================================
# 3ds Max Worker 服务环境变量配置
# 此服务运行在安装了 3ds Max 的 Windows 机器上
# ============================================================

# 3dsmaxbatch.exe 完整路径
# 根据你安装的 3ds Max 版本修改年份
MAX_EXE_PATH=C:\Program Files\Autodesk\3ds Max 2024\3dsmaxbatch.exe

# 工作目录（脚本和输出文件的临时存放位置）
WORK_DIR=C:\cad_agent_work

# 单个任务超时时间（秒）
TIMEOUT_SECONDS=300

# 最大并发任务数（建议不超过 2，3ds Max 很吃内存）
MAX_CONCURRENT_TASKS=2

# 服务监听地址
HOST=0.0.0.0

# 服务监听端口
PORT=8765

# API 认证 Token（留空则不验证，生产环境请设置）
SECRET_TOKEN=

# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
